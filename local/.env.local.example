# Local-only development defaults. Do not use these in SAE/production.
# Copy to local/.env.local and edit if needed.
XMPP_DOMAIN=xmpp.narsk.dpdns.org
EJABBERD_LOG_LEVEL=info

POSTGRES_DB=ejabberd
POSTGRES_USER=ejabberd
POSTGRES_PASSWORD=ejabberd_local_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_local_password

MESSAGE_FILTER_API_URL=http://host.docker.internal:18088/verify
MESSAGE_FILTER_API_KEY=
OFFLINE_PUSH_URL=http://host.docker.internal:18088/notify
OFFLINE_PUSH_API_KEY=
